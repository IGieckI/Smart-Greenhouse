      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB-IoT"
          },
          "query": "import \"math\"\n\nfrom(bucket: \"${bucket_clean}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensor_measurements\")\n  // Filtriamo per i tre campi necessari\n  |> filter(fn: (r) => r[\"_field\"] == \"air_temp\" or r[\"_field\"] == \"leaf_temp\" or r[\"_field\"] == \"humidity\")\n  |> filter(fn: (r) => r[\"id_board\"] == \"${id_board_var}\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  // Allineiamo i dati in base al tempo per avere i campi come colonne\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  // Ignoriamo le righe in cui manca uno dei valori fondamentali per evitare errori matematici\n  |> filter(fn: (r) => exists r.air_temp and exists r.leaf_temp and exists r.humidity)\n  |> map(fn: (r) => {\n      // 1. Calcolo Pressione di Vapore Satura (SVP) in kPa\n      svp_air = 0.61078 * math.exp(x: (17.27 * r.air_temp) / (r.air_temp + 237.3))\n      svp_leaf = 0.61078 * math.exp(x: (17.27 * r.leaf_temp) / (r.leaf_temp + 237.3))\n      \n      // 2. Calcolo Pressione di Vapore Attuale (AVP) dell'aria in base all'umidità relativa\n      avp = svp_air * (r.humidity / 100.0)\n      \n      // 3. Calcolo VPD (in kPa)\n      vpd_air = svp_air - avp\n      vpd_leaf = svp_leaf - avp\n      \n      return {\n          _time: r._time,\n          VPD_air: vpd_air,\n          VPD_leaf: vpd_leaf\n      }\n  })",
          "refId": "A"
        }
      ],
      "title": "VPD",
      "type": "timeseries"
    },
