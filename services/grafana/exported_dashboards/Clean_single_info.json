      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB-IoT"
          },
          "query": "import \"math\"\n\n// Recuperiamo il valore dal selettore della dashboard\nwindow_minutes_val = ${window_minutes}\nwindow_set = duration(v: string(v: window_minutes_val) + \"m\")\n\n// Funzione interna per la Pressione di Vapore Satura (SVP)\nsvp = (t) => 0.61078 * math.exp(x: (17.27 * t) / (t + 237.3))\n\nfrom(bucket: \"${bucket_clean}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensor_measurements\")\n  |> filter(fn: (r) => r[\"id_board\"] == \"${id_board_var}\")\n  |> filter(fn: (r) => \n      r[\"_field\"] == \"air_temp\" or \n      r[\"_field\"] == \"leaf_temp\" or \n      r[\"_field\"] == \"humidity\" or\n      r[\"_field\"] == \"air_temp_pred\" or\n      r[\"_field\"] == \"leaf_temp_pred\" or\n      r[\"_field\"] == \"humidity_pred\"\n  )\n  |> aggregateWindow(every: window_set, fn: mean, createEmpty: false)\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => exists r.air_temp and exists r.humidity)\n  |> map(fn: (r) => {\n      \n      // --- DATI REALI ---\n      svp_air = svp(t: r.air_temp)\n      avp_air = svp_air * (r.humidity / 100.0)\n      v_air = svp_air - avp_air\n      \n      // FIX: Oltre a verificare che esista, scartiamo i codici di errore hardware (es. -127 o 0 anomali)\n      // Se la tua scheda invia esattamente 0.0 quando si rompe/scollega, cambia > -20.0 con > 0.5\n      has_leaf = if exists r.leaf_temp then r.leaf_temp > -20.0 else false\n      v_leaf = if has_leaf then svp(t: r.leaf_temp) - avp_air else float(v: \"NaN\")\n      \n      \n      // --- PREDIZIONI ---\n      // FIX: Nessun fallback sui dati reali. Se non abbiamo le predizioni salvate, le ignoriamo.\n      has_env_pred = exists r.air_temp_pred and exists r.humidity_pred\n      \n      svp_air_pred = if has_env_pred then svp(t: r.air_temp_pred) else float(v: \"NaN\")\n      avp_pred = if has_env_pred then svp_air_pred * (r.humidity_pred / 100.0) else float(v: \"NaN\")\n      \n      v_air_pred = if has_env_pred then svp_air_pred - avp_pred else float(v: \"NaN\")\n      \n      // Per avere il VPD fogliare predetto, ci servono sia le predizioni ambientali sia quelle fogliari\n      has_leaf_pred = exists r.leaf_temp_pred\n      v_leaf_pred = if has_env_pred and has_leaf_pred then \n                        svp(t: r.leaf_temp_pred) - avp_pred \n                    else \n                        float(v: \"NaN\")\n\n      return {\n          _time: r._time,\n          VPD_air: v_air,\n          VPD_leaf: v_leaf,\n          VPD_air_pred: v_air_pred,\n          VPD_leaf_pred: v_leaf_pred\n      }\n  })",
          "refId": "A"
        }
      ],
      "title": "VPD",
      "type": "timeseries"
    },
