        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB-IoT"
          },
          "query": "base_data = from(bucket: \"${bucket_clean}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensor_measurements\" and r[\"id_board\"] == \"${id_board_var}\")\n  |> filter(fn: (r) => contains(value: r[\"_field\"], set: [\"air_temp\", \"air_temp_pred\", \"leaf_temp\", \"leaf_temp_pred\"]))\n  |> group(columns: [\"_measurement\", \"_field\", \"id_board\"])\n  |> aggregateWindow(every: 15m, fn: mean, createEmpty: false)\n\n// 2. MASSIMI GIORNALIERI\ndata_max = base_data\n  |> aggregateWindow(every: 1d, fn: max, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r._field + \"_max\" }))\n\n// 3. MINIMI GIORNALIERI\ndata_min = base_data\n  |> aggregateWindow(every: 1d, fn: min, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r._field + \"_min\" }))\n\n// 4. UNIONE, PIVOT E TIMELINE (Ultimi 3 Giorni)\nunion(tables: [data_max, data_min])\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 3)\n  |> sort(columns: [\"_time\"], desc: false)\n  |> drop(columns: [\"_start\", \"_stop\", \"_measurement\", \"id_board\"])",
          "refId": "A"
        }
      ],
      "title": "Daily min/max on main temperature",
      "type": "barchart"
