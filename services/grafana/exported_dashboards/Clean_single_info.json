          "query": "// Finestra parametrizzabile definita a livello di dashboard (es. stringa \"5m\" o variabile numerica)\nwindow_set = ${window_minutes}m\n\nfrom(bucket: \"${bucket_clean}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensor_measurements\")\n  // Includiamo \"air_temp_pred\" insieme ai tre campi storici richiesti\n  |> filter(fn: (r) => contains(value: r[\"_field\"], set: [\"air_temp\", \"leaf_temp\", \"water_temp\", \"air_temp_pred\"]))\n  |> filter(fn: (r) => r[\"id_board\"] == \"${id_board_var}\")\n  // Finestra di aggregazione dinamica e parametrizzabile per ripulire il rumore\n  |> aggregateWindow(every: window_set, fn: mean, createEmpty: false)",
