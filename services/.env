# -------------------------
# INFLUXDB CONFIGURATIONS
# -------------------------
INFLUX_URL=http://influxdb:8086
INFLUX_ORG=iot_org
INFLUX_BUCKET=sensor_data
# ATTENZIONE: Questo token deve essere generato dall'interfaccia UI di InfluxDB (su localhost:8086) 
# al primissimo avvio. Prima di generarlo, metti un token fittizio per far partire i container, 
# poi lo andrai a sostituire e riavvierai il controller.
INFLUX_TOKEN=TokenFittizio

# -------------------------
# CONTROLLER CONFIGURATIONS
# -------------------------
LEAF_TEMP_LABEL=leaf_temperature

# -------------------------
# MQTT LORAWAN CONFIGURATIONS
# -------------------------
MQTT_BROKER=eu1.cloud.thethings.network
MQTT_PORT=1883
MQTT_TOPIC=v3/+/devices/+/up

